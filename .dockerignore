# Git
.git
.gitignore

# Node（构建时需要安装，所以排除）
node_modules
packages/*/node_modules
packages/*/dist

# 构建缓存
.turbo
dist

# 测试和文档（不需要复制到镜像）
test/
docs/
examples/
*.md
!README.md

# 开发工具
.husky
eslint.config.mjs
*.bat
diagnose.*
verify-*
quick-test.*
test-fetch-*
test-setup.*

# 临时文件
*.log
*.tmp
.DS_Store
Thumbs.db

# Python
__pycache__
*.pyc
*.pyo
.venv
venv/

# Docker 相关（避免递归复制）
Dockerfile*
docker-compose*.yml
.dockerignore
